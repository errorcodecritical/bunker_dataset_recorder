        Grid: false
        Hesai QT128: true
        Hugin D1: false
        OAK-D-W: false
        RobotModel: false
        TF: false
        Value: true
      Zoom Factor: 1
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: base_link
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
