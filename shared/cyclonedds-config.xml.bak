<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
    <Domain Id="any">
        <General>
            <Interfaces>
                <!-- Bind to the exact Wi-Fi interface name on THIS robot -->
                <NetworkInterface name="wlP1p1s0" priority="default"/>
            </Interfaces>
            <AllowMulticast>false</AllowMulticast>
            <!-- Leave MaxMessageSize at a realistic value; do NOT shrink below default
                 unless you know your largest topic fits. FragmentSize controls the
                 wire fragment size for Wi-Fi MTU safety. -->
            <MaxMessageSize>65500B</MaxMessageSize>
            <FragmentSize>1400B</FragmentSize>
        </General>
        <Internal>
            <!-- 100ms is a safer default for Wi-Fi; 30ms can flood the channel
                 with heartbeat/ACKNACK traffic and stall reassembly of larger samples -->
            <HeartbeatInterval>100ms</HeartbeatInterval>
            <SocketReceiveBufferSize min="10MB"/>
            <SocketSendBufferSize min="10MB"/>
        </Internal>
        <Discovery>
            <!-- CRITICAL: every participant (host, every container, every robot)
                 must list every OTHER participant it needs to talk to.
                 This list must be symmetric across all machines/containers. -->
            <Peers>
                <Peer Address="127.0.0.1"/>      <!-- self / host <-> container -->
                <Peer Address="172.16.1.100"/>   <!-- BUNKER -->
                <Peer Address="172.16.1.101"/>   <!-- CURTMINI -->
                <!-- Add this robot's own LAN IP too if other robots need to reach it,
                     and add every robot's IP to every robot's list, not just this one -->
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
            <LeaseDuration>10s</LeaseDuration>
        </Discovery>
    </Domain>
</CycloneDDS>
